{
  "name": "Order",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "order",
        "waiter_call"
      ]
    },
    "table_number": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "qty": {
            "type": "number"
          },
          "price": {
            "type": "number"
          }
        }
      }
    },
    "waiter_call_label": {
      "type": "string"
    },
    "total": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "ready",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    },
    "cancel_reason": {
      "type": "string"
    }
  },
  "required": [
    "type"
  ],
  "rls": {
    "create": {},
    "read": {},
    "update": {},
    "delete": {}
  }
}